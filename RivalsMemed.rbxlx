-- ═══════════════════════════════════════════════
--  UTILS
-- ═══════════════════════════════════════════════
local function newUI(class, props, parent)
	local obj=Instance.new(class)
	for k,v in pairs(props) do obj[k]=v end
	if parent then obj.Parent=parent end
	return obj
end
local function corner(r,p) local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,r); c.Parent=p end
local function fmt(n) if n&gt;=1e6 then return string.format("%.1fm",n/1e6) elseif n&gt;=1e3 then return string.format("%.1fk",n/1e3) else return tostring(math.floor(n)) end end

-- ═══════════════════════════════════════════════
